// A launch configuration that compiles the extension and then opens it inside a new window
{
        "version": "0.2.0",
        "configurations": [
                {
                        "type": "extensionHost",
                        "request": "launch",
                        "name": "Launch Client",
                        "runtimeExecutable": "${execPath}",
                        "outFiles": [
                                "${workspaceRoot}/client/out/**/*.js",
                                "${workspaceRoot}/server/out/**/*.js"
                        ],
                        "autoAttachChildProcesses": true,
                        "preLaunchTask": {
                                "type": "npm",
                                "script": "watch"
                        }
                },
                {
                        "type": "extensionHost",
                        "request": "launch",
                        "name": "Launch Client (The Look)",
                        "runtimeExecutable": "${execPath}",
                        "args": [
                                "--extensionDevelopmentPath=${workspaceRoot}",
                                "${workspaceRoot}/../thelook"
                        ],
                        "outFiles": [
                                "${workspaceRoot}/client/out/**/*.js",
                                "${workspaceRoot}/server/out/**/*.js"
                        ],
                        "autoAttachChildProcesses": true,
                        "preLaunchTask": {
                                "type": "npm",
                                "script": "watch"
                        }
                },
                {
                        "type": "extensionHost",
                        "request": "launch",
                        "name": "Launch Client (The Look Backup)",
                        "runtimeExecutable": "${execPath}",
                        "args": [
                                "--extensionDevelopmentPath=${workspaceRoot}",
                                "${workspaceRoot}/../thelook-backup"
                        ],
                        "outFiles": [
                                "${workspaceRoot}/client/out/**/*.js",
                                "${workspaceRoot}/server/out/**/*.js"
                        ],
                        "autoAttachChildProcesses": true,
                        "preLaunchTask": {
                                "type": "npm",
                                "script": "watch"
                        }
                },
                {
                        "type": "extensionHost",
                        "request": "launch",
                        "name": "Launch Client (Call Center Demo)",
                        "runtimeExecutable": "${execPath}",
                        "args": [
                                "--extensionDevelopmentPath=${workspaceRoot}",
                                "${workspaceRoot}/../call_center_demo"
                        ],
                        "outFiles": [
                                "${workspaceRoot}/client/out/**/*.js",
                                "${workspaceRoot}/server/out/**/*.js"
                        ],
                        "autoAttachChildProcesses": true,
                        "preLaunchTask": {
                                "type": "npm",
                                "script": "watch"
                        }
                },
                {
                        "type": "extensionHost",
                        "request": "launch",
                        "name": "Launch Client (Healthcare Demo)",
                        "runtimeExecutable": "${execPath}",
                        "args": [
                                "--extensionDevelopmentPath=${workspaceRoot}",
                                "${workspaceRoot}/../healthcare_demo"
                        ],
                        "outFiles": [
                                "${workspaceRoot}/client/out/**/*.js",
                                "${workspaceRoot}/server/out/**/*.js"
                        ],
                        "autoAttachChildProcesses": true,
                        "preLaunchTask": {
                                "type": "npm",
                                "script": "watch"
                        }
                },
                {
                        "type": "node",
                        "request": "launch",
                        "name": "Run Server Tests",
                        "runtimeExecutable": "npm",
                        "runtimeArgs": [
                            "run",
                            "test",
                            "--",
                            "--runInBand"
                        ],
                        "cwd": "${workspaceFolder}/server",
                        "console": "integratedTerminal",
                        "internalConsoleOptions": "neverOpen"
                },
                {
                        "type": "node",
                        "request": "launch",
                        "name": "Debug Current Test File",
                        "program": "${workspaceFolder}/node_modules/.bin/jest",
                        "args": [
                            "${relativeFile}",
                            "--runInBand",
                            "--colors",
                            "--verbose=false"
                        ],
                        "console": "integratedTerminal",
                        "internalConsoleOptions": "neverOpen"
                },
                {
                        "type": "node",
                        "request": "launch",
                        "name": "Debug Test by Pattern",
                        "program": "${workspaceFolder}/node_modules/.bin/jest",
                        "args": [
                            "${input:testPattern}",
                            "--runInBand",
                            "--colors",
                            "--verbose=false"
                        ],
                        "console": "integratedTerminal",
                        "internalConsoleOptions": "neverOpen"
                }
        ],
        "inputs": [
                {
                        "id": "testPattern",
                        "type": "promptString",
                        "description": "Test name or pattern (e.g. dimension_group/index.test.ts)",
                        "default": "dimension_group/index.test.ts"
                }
        ]
}
