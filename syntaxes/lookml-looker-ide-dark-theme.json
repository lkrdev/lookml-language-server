{
  "name": "Looker IDE (Dark)",
  "type": "dark",
  "colors": {
    "editor.background": "#1E1E1E",
    "editor.foreground": "#D4D4D4",
    "editorLineNumber.foreground": "#858585",
    "editorLineNumber.activeForeground": "#C6C6C6"
  },
  "tokenColors": [
    {
      "scope": [
        "constant.numeric.lookml",
        "source.lookml.sql.numeric"
      ],
      "settings": {
        "foreground": "#c77528"
      }
    },
    {
      "scope": [
        "string.quoted.double.lookml",
        "string.quoted.single.lookml",
        "string.quoted.other.backtick.lookml",
        "constant.character.escape.lookml"
      ],
      "settings": {
        "foreground": "#c77528"
      }
    },
    {
      "scope": [
        "source.lookml.scope"
      ],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "scope": [
        "source.lookml.scope.type",
        "keyword.control.lookml",
        "support.type.lookml"
      ],
      "settings": {
        "foreground": "#6997bf"
      }
    },
    {
      "scope": [
        "source.lookml.scope.name",
        "support.property.lookml",
        "entity.name.type.lookml"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": [
        "source.lookml.scope.start",
        "source.lookml.scope.end",
        "punctuation.definition.block.begin.lookml",
        "punctuation.definition.block.end.lookml",
        "source.lookml.sql.parameter.close"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": [
        "source.lookml.parameter.name",
        "source.lookml.sql.parameter.name",
        "punctuation.separator.key-value.lookml"
      ],
      "settings": {
        "foreground": "#6997bf"
      }
    },
    {
      "scope": [
        "source.lookml.variable",
        "variable.parameter.lookml",
        "variable.other.lookml"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "scope": [
        "source.lookml.parameter.value.yesno",
        "source.lookml.sql.constant.language",
        "constant.language.lookml"
      ],
      "settings": {
        "foreground": "#C586C0"
      }
    },
    {
      "scope": [
        "source.lookml.parameter.array",
        "source.lookml.parameter.value",
        "source.lookml.sql.parameter.value"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": [
        "source.lookml.sql.function.name",
        "source.lookml.sql.function.scope.start",
        "source.lookml.sql.function.scope.end"
      ],
      "settings": {
        "foreground": "#6997bf"
      }
    },
    {
      "scope": [
        "source.lookml.liquid.tag"
      ],
      "settings": {
        "foreground": "#0C6FFF"
      }
    },
    {
      "scope": [
        "source.lookml.liquid.output"
      ],
      "settings": {
        "foreground": "#17a6b0"
      }
    },
    {
      "scope": [
        "source.lookml.liquid.filter"
      ],
      "settings": {
        "foreground": "#3595a6"
      }
    },
    {
      "scope": [
        "source.lookml.comment",
        "comment.line.number-sign.lookml"
      ],
      "settings": {
        "foreground": "#6A9955",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.array.begin.lookml",
        "punctuation.definition.array.end.lookml",
        "punctuation.terminator.sql.lookml"
      ],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "scope": [
        "source.lookml.constant"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "scope": [
        "source.lookml.sql.keyword",
        "source.lookml.sql.function.argument.keyword",
        "keyword.operator.expression.lookml"
      ],
      "settings": {
        "foreground": "#6997bf"
      }
    },
    {
      "scope": [
        "source.lookml.sql.keyword.main"
      ],
      "settings": {
        "foreground": "#6997bf"
      }
    },
    {
      "scope": [
        "source.lookml.sql.keyword.type"
      ],
      "settings": {
        "foreground": "#6997bf"
      }
    },
    {
      "scope": [
        "source.lookml.liquid"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    }
  ]
}
